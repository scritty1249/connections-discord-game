{
    "version": 2,
    "rewrites": [
        {
            "source": "/",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/refresh-gamestate",
            "schedule": "1 0 * * *"
        }
    ],
    "functions": {
        "api/*.js": {
            "includeFiles": "public/fonts/**/*.otf"
        }
    }
}
